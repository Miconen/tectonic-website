# Base URL of the Tectonic API (server-only, never sent to browser)
API_BASE_URL=http://localhost:8080

# Basic Auth credentials for the API (temporary)
API_AUTH_USER=admin
API_AUTH_PASS=secret

# Optional: when set, bare URLs (e.g. /leaderboard) resolve to this guild.
# When unset, all routes must include a guild id segment (e.g. /123456789012345678/leaderboard).
DEFAULT_GUILD_ID=

# Port for adapter-node (Railway injects its own PORT)
PORT=3000
